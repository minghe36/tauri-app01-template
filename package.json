{
  "name": "app01-tpl",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "haoshu",
  "copyright": "Copyright © 2026 haoshu. All rights reserved.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "typescript-eslint": {
      "typescript": "$typescript"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm --workspace @app/desktop run dev",
    "build": "npm --workspace @app/desktop run build",
    "preview": "npm --workspace @app/desktop run preview",
    "typecheck": "npm --workspace @app/desktop run typecheck",
    "lint": "npm --workspace @app/desktop run lint",
    "lint:fix": "npm --workspace @app/desktop run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm --workspace @app/desktop run test",
    "test:run": "npm --workspace @app/desktop run test:run",
    "test:ui": "npm --workspace @app/desktop run test:ui",
    "test:coverage": "npm --workspace @app/desktop run test:coverage",
    "rust:fmt": "npm --workspace @app/desktop run rust:fmt",
    "rust:fmt:check": "npm --workspace @app/desktop run rust:fmt:check",
    "rust:clippy": "npm --workspace @app/desktop run rust:clippy",
    "rust:clippy:fix": "npm --workspace @app/desktop run rust:clippy:fix",
    "rust:test": "npm --workspace @app/desktop run rust:test",
    "rust:bindings": "npm --workspace @app/desktop run rust:bindings",
    "tauri": "npm --workspace @app/desktop run tauri",
    "tauri:desktop": "npm --workspace @app/desktop run tauri",
    "tauri:mobile": "npm --workspace @app/mobile run tauri",
    "tauri:dev": "npm run tauri:dev:desktop",
    "tauri:dev:desktop": "npm --workspace @app/desktop run tauri:dev",
    "tauri:dev:mobile": "npm --workspace @app/mobile run tauri:dev",
    "tauri:dev:android": "npm --workspace @app/mobile run tauri:dev:android",
    "tauri:dev:ios": "npm --workspace @app/mobile run tauri:dev:ios",
    "tauri:build": "npm run tauri:build:desktop",
    "tauri:build:desktop": "npm --workspace @app/desktop run tauri:build",
    "tauri:build:mobile": "npm --workspace @app/mobile run tauri:build",
    "tauri:build:android": "npm --workspace @app/mobile run tauri:build:android",
    "tauri:build:ios": "npm --workspace @app/mobile run tauri:build:ios",
    "tauri:check": "npm --workspace @app/desktop run tauri:check",
    "test:all": "npm run test:run && npm run rust:test",
    "check:all": "npm run typecheck && npm run lint && npm run ast:lint && npm run format:check && npm run rust:fmt:check && npm run rust:clippy && npm run test:run && npm run rust:test",
    "fix:all": "npm run lint:fix && npm run format && npm run rust:fmt && npm run rust:clippy:fix",
    "build:analyze": "npm --workspace @app/desktop run build:analyze",
    "release:prepare": "node scripts/prepare-release.js",
    "task:complete": "node scripts/complete-task.js",
    "task:rename-done": "node scripts/complete-task.js --rename-existing",
    "knip": "knip",
    "jscpd": "jscpd",
    "ast:lint": "ast-grep scan",
    "ast:fix": "ast-grep scan --fix"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-log": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^25.7.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.0",
    "react-resizable-panels": "^3.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.0",
    "@eslint/js": "^9.39.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.15",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jscpd": "^4.0.5",
    "jsdom": "^29.0.1",
    "knip": "^6.0.6",
    "prettier": "^3.7.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.3",
    "vitest": "^4.0.15",
    "zod-validation-error": "^4.0.2"
  }
}
